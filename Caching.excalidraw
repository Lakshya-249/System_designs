    {
      "id": "lnzLVHsp47tckWTQmcuRg",
      "type": "text",
      "x": 318.89517334761257,
      "y": 5326.25172558836,
      "width": 1746.5914306640625,
      "height": 105,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5r",
      "roundness": null,
      "seed": 2067690800,
      "version": 568,
      "versionNonce": 909106992,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1779700381505,
      "link": null,
      "locked": false,
      "text": "Note: If the Queue itself goes, down we can lost the messages, but today lots of queues persists the data on disk(like kafka,\nthat stores these logs across many brokers so that if one broker goes down other can start where previous one left) , \nso if one broker goes down the replica has the dataor previous messages to process the data.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: If the Queue itself goes, down we can lost the messages, but today lots of queues persists the data on disk(like kafka,\nthat stores these logs across many brokers so that if one broker goes down other can start where previous one left) , \nso if one broker goes down the replica has the dataor previous messages to process the data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
