    },
    {
      "id": "A4Kg5UAZQUnrOOtcauOLv",
      "type": "text",
      "x": 587.2421875,
      "y": -2472,
      "width": 917.2991943359375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5v",
      "roundness": null,
      "seed": 27049264,
      "version": 258,
      "versionNonce": 785869776,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779700608055,
      "link": null,
      "locked": false,
      "text": "A cache is a temporary storage that keeps that keeps the recently used data so that u can \nget it much faster next time, by passing the whole db call .",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A cache is a temporary storage that keeps that keeps the recently used data so that u can \nget it much faster next time, by passing the whole db call .",
      "autoResize": true,
      "lineHeight": 1.25
    },
