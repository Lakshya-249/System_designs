    {
      "id": "M5f6aonUojGpGXRrF9Ji4",
      "type": "text",
      "x": 559.88671875,
      "y": 2064.203125,
      "width": 1225.4989013671875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
