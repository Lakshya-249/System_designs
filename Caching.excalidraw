    {
      "id": "cfpt58vKTlM9bijfsgdWg",
      "type": "text",
      "x": 618.046875,
      "y": 3571.6875,
      "width": 966.8590698242188,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b9M",
      "roundness": null,
      "seed": 826919888,
      "version": 357,
      "versionNonce": 856721360,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779822041834,
      "link": null,
      "locked": false,
      "text": "Solutions: \n(i) If consistency is really important then we can invalidate the data in cache on write to db.\n(ii) Have the cached data with a short TTL entry. \n(iii) If Eventual Consistency is not the problem we leave the stale data as it is with larger TTLs. \nif it does not hurt our logic/user experience.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solutions: \n(i) If consistency is really important then we can invalidate the data in cache on write to db.\n(ii) Have the cached data with a short TTL entry. \n(iii) If Eventual Consistency is not the problem we leave the stale data as it is with larger TTLs. \nif it does not hurt our logic/user experience.",
      "autoResize": true,
      "lineHeight": 1.25
    },
