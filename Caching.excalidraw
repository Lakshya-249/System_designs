    {
      "id": "fAmxxzCaG75t5cZy2hdTw",
      "type": "text",
      "x": 649.78125,
      "y": 4259.44140625,
      "width": 1007.4791870117188,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b9g",
      "roundness": null,
      "seed": 1506085840,
      "version": 502,
      "versionNonce": 52821296,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779822783455,
      "link": null,
      "locked": false,
      "text": "Solutions:\n(i) Put the hot keys in the each of the shard/cache in your cache cluster and then we can loadbalance\nthe request to the shards / cache servers.\n(ii) Using the In process caching idea, where we can add a fallback cache on the server itself, \nso that it doesn't need to request the cache server again and again.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solutions:\n(i) Put the hot keys in the each of the shard/cache in your cache cluster and then we can loadbalance\nthe request to the shards / cache servers.\n(ii) Using the In process caching idea, where we can add a fallback cache on the server itself, \nso that it doesn't need to request the cache server again and again.",
      "autoResize": true,
      "lineHeight": 1.25
    },
