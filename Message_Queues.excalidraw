    {
      "id": "RoqbaOSGdcRWA68lolrQP",
      "type": "text",
      "x": 417.74552974016376,
      "y": 1946.2283258812595,
      "width": 1494.4503173828125,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
