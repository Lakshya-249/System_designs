      "seed": 86599632,
      "version": 351,
      "versionNonce": 1293075920,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779644284457,
      "link": null,
      "locked": false,
      "text": "When the producer is producing queue message faster then consumer consumes it:\n(i) Add more consumers\n(ii) Partition the queue into multiple independent sequences to be processed parallely\n(iii) Slow down the producers by rejecting/dropping requests",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the producer is producing queue message faster then consumer consumes it:\n(i) Add more consumers\n(ii) Partition the queue into multiple independent sequences to be processed parallely\n(iii) Slow down the producers by rejecting/dropping requests",
      "autoResize": true,
      "lineHeight": 1.25
    },
