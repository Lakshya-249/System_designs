    {
      "id": "d1LLDQBmQe535qKHcm1b7",
      "type": "text",
      "x": 526.3581752590316,
      "y": 3788.9254543493225,
      "width": 1158.1126708984375,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
