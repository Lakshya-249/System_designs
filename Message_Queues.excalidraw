      "groupIds": [],
      "frameId": null,
      "index": "b5r",
      "roundness": null,
      "seed": 2067690800,
      "version": 503,
      "versionNonce": 483423024,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779645852806,
      "link": null,
      "locked": false,
      "text": "Note: If the Queue itself goes, down we can lost the messages, but today lots of queues persists the data on disk(like kafka, that stores these\nlogs across many brokers so that if one broker goes down other can start where previous one left) , so if one broker goes down the replica has the data\nor previous messages to process the data.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: If the Queue itself goes, down we can lost the messages, but today lots of queues persists the data on disk(like kafka, that stores these\nlogs across many brokers so that if one broker goes down other can start where previous one left) , so if one broker goes down the replica has the data\nor previous messages to process the data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
