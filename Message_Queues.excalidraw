    {
      "id": "lnzLVHsp47tckWTQmcuRg",
      "type": "text",
      "x": 224.1957118874156,
      "y": 5328.736446876279,
      "width": 2111.208984375,
      "height": 105,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
